{
  "notebooklm_home": "~/.notebooklm",
  "data_dir": "~/.openclaw/notebooklm-data",
  "cache_ttl_query": 3600,
  "cache_ttl_source_list": 86400,
  "rate_limit_per_minute": 10,
  "rate_limit_per_hour": 100,
  "lock_timeout": 60,
  "retry_max": 3,
  "retry_backoff_base": 2,
  "retry_backoff_max": 120,
  "content_filter_deny": [
    "~/.ssh/.*",
    "~/.gnupg/.*",
    ".*secrets.*",
    ".*\\.env.*",
    ".*credentials.*",
    ".*password.*",
    ".*api.key.*",
    ".*token.*\\.json"
  ],
  "health_check_interval_hours": 6,
  "artifact_staging_ttl_hours": 24,
  "pinned_version": "0.3.2",
  "proxy": "http://127.0.0.1:8234"
}