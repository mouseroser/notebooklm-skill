# --- Command: notebooks ---

cmd_notebooks() {
  local agent_id="$1" subcmd="${2:-list}"
  local _start_ts=$SECONDS

  case "$subcmd" in
    list)
      audit_log "$agent_id" "" "notebooks-list" "ok" "$(( SECONDS - _start_ts ))"
      registry_list
      ;;
    get)
      audit_log "$agent_id" "${3:-}" "notebooks-get" "ok" "$(( SECONDS - _start_ts ))"
      registry_get "${3:-}"
      ;;
    add)
      local acl_result
      acl_result=$(check_acl "$agent_id" "" "registry-edit")
      if [[ $(echo "$acl_result" | jq -r '.allowed') != "true" ]]; then
        audit_log "$agent_id" "" "notebooks-add" "denied" "$(( SECONDS - _start_ts ))" "acl_denied"
        echo "$acl_result"
        return 1
      fi
      local result
      result=$(registry_add "${3:-}" "${4:-}" "${5:-}")
      audit_log "$agent_id" "${3:-}" "notebooks-add" "ok" "$(( SECONDS - _start_ts ))"
      echo "$result"
      ;;
    remove)
      local acl_result
      acl_result=$(check_acl "$agent_id" "" "registry-edit")
      if [[ $(echo "$acl_result" | jq -r '.allowed') != "true" ]]; then
        audit_log "$agent_id" "" "notebooks-remove" "denied" "$(( SECONDS - _start_ts ))" "acl_denied"
        echo "$acl_result"
        return 1
      fi
      local result
      result=$(registry_remove "${3:-}")
      audit_log "$agent_id" "${3:-}" "notebooks-remove" "ok" "$(( SECONDS - _start_ts ))"
      echo "$result"
      ;;
    *)
      json_error "invalid_args" "Unknown notebooks subcommand: $subcmd" "Valid: list, get, add, remove"
      return 1
      ;;
  esac
}

# --- Command: health (Fix #7: validate_auth defense) ---

cmd_health() {
  local agent_id="$1"
  local _start_ts=$SECONDS

  local acl_result
  acl_result=$(check_acl "$agent_id" "" "health-check")
  if [[ $(echo "$acl_result" | jq -r '.allowed') != "true" ]]; then
    audit_log "$agent_id" "" "health" "denied" "$(( SECONDS - _start_ts ))" "acl_denied"
    echo "$acl_result"
    return 1
  fi

  local auth_ok="false"
  local auth_message=""
  local auth_result
  auth_result=$(validate_auth 2>/dev/null) || true

  # Fix #7: Defend against non-JSON output from validate_auth
  if echo "$auth_result" | jq empty 2>/dev/null; then
    auth_ok=$(echo "$auth_result" | jq -r '.ok // false')
    auth_message=$(echo "$auth_result" | jq -r '.message // ""')
  else
    auth_ok="false"
    auth_message="validate_auth returned non-JSON output"
  fi

  local nb_count=0
  local registry_result
  registry_result=$(registry_list 2>/dev/null) || true
  nb_count=$(echo "$registry_result" | jq -r '.count // 0')

  local cache_size="0"
  if [[ -d "$CACHE_DIR" ]]; then
    cache_size=$(du -sk "$CACHE_DIR" 2>/dev/null | cut -f1)
  fi

  audit_log "$agent_id" "" "health" "ok" "$(( SECONDS - _start_ts ))"
  jq -n -c \
    --argjson auth "$auth_ok" \
    --arg auth_msg "$auth_message" \
    --argjson nb_count "$nb_count" \
    --argjson cache_kb "${cache_size:-0}" \
    --arg data_dir "$DATA_DIR" \
    '{ok: true, auth: $auth, auth_message: $auth_msg, notebooks_registered: $nb_count, cache_size_kb: $cache_kb, data_dir: $data_dir}'
  return 0
}

# --- Main Dispatch ---

usage() {
  cat << 'USAGE'
{
  "usage": "nlm-gateway.sh <command> [options]",
  "commands": {
    "query":     "--agent <id> --notebook <name> --query <text> [--no-cache]",
    "source":    "--agent <id> --subcmd <add|list|remove> --notebook <name> [--path <path>] [--source-id <id>] [--no-cache]",
    "artifact":  "--agent <id> --subcmd <generate|download> --notebook <name> [args...]",
    "research":  "--agent <id> --notebook <name> --query <text>",
    "notebooks": "--agent <id> --subcmd <list|get|add|remove> [--name <n>] [--id <id>] [--desc <d>]",
    "health":    "--agent <id>"
  }
}
USAGE
}

main() {
  local command="${1:-}"
  shift 2>/dev/null || true

  if [[ -z "$command" || "$command" == "--help" || "$command" == "-h" ]]; then
    usage
    return 0
  fi

  # Parse common flags
  local agent_id="" notebook="" query="" subcmd="" no_cache="false"
  local source_path="" source_id="" nb_name="" nb_id="" nb_desc=""
  local extra_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agent)     agent_id="$2"; shift 2 ;;
      --notebook)  notebook="$2"; shift 2 ;;
      --query)     query="$2"; shift 2 ;;
      --subcmd)    subcmd="$2"; shift 2 ;;
      --no-cache)  no_cache="true"; shift ;;
      --path)      source_path="$2"; shift 2 ;;
      --source-id) source_id="$2"; shift 2 ;;
      --name)      nb_name="$2"; shift 2 ;;
      --id)        nb_id="$2"; shift 2 ;;
      --desc)      nb_desc="$2"; shift 2 ;;
      *)           extra_args+=("$1"); shift ;;
    esac
  done

  if [[ -z "$agent_id" ]]; then
    json_error "invalid_args" "agent_id required (--agent)"
    return 1
  fi

  # Fix #8: Lock is now acquired per-command only when CLI call is needed
  # (not globally here). Read-only cache-hit paths skip locking entirely.

  # Dispatch
  case "$command" in
    query)
      cmd_query "$agent_id" "$notebook" "$query" "$no_cache"
      ;;
    source)
      case "$subcmd" in
        add)    cmd_source "$agent_id" "add" "$notebook" "$source_path" ;;
        list)   cmd_source "$agent_id" "list" "$notebook" "$no_cache" ;;
        remove) cmd_source "$agent_id" "remove" "$notebook" "$source_id" ;;
        *)      json_error "invalid_args" "source requires --subcmd add|list|remove" ;;
      esac
      ;;
    artifact)
      cmd_artifact "$agent_id" "${subcmd:-generate}" "$notebook" "${extra_args[@]}"
      ;;
    research)
      cmd_research "$agent_id" "$notebook" "$query"
      ;;
    notebooks)
      cmd_notebooks "$agent_id" "${subcmd:-list}" "$nb_name" "$nb_id" "$nb_desc"
      ;;
    health)
      cmd_health "$agent_id"
      ;;
    *)
      json_error "unknown_command" "Unknown command: $command"
      return 1
      ;;
  esac

  return $?
}

main "$@"
