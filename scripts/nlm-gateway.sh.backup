#!/bin/bash
# nlm-gateway.sh — NotebookLM OpenClaw Gateway (main entry point)
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
export DATA_DIR="${DATA_DIR:-$HOME/.openclaw/notebooklm-data}"
export SETTINGS_FILE="$SKILL_DIR/config/settings.json"
export CACHE_DIR="$DATA_DIR/cache"
export LOCK_DIR="$DATA_DIR/lock/nlm.lock"
export AUDIT_LOG="$DATA_DIR/logs/audit.jsonl"

# Source libraries
source "$SCRIPT_DIR/lib/lock.sh"
source "$SCRIPT_DIR/lib/auth.sh"
source "$SCRIPT_DIR/lib/acl.sh"
source "$SCRIPT_DIR/lib/cache.sh"
source "$SCRIPT_DIR/lib/queue.sh"
source "$SCRIPT_DIR/lib/registry.sh"

# Load settings
LOCK_TIMEOUT=$(jq -r '.lock_timeout // 60' "$SETTINGS_FILE" 2>/dev/null)
CACHE_TTL_QUERY=$(jq -r '.cache_ttl_query // 3600' "$SETTINGS_FILE" 2>/dev/null)
CACHE_TTL_SOURCE_LIST=$(jq -r '.cache_ttl_source_list // 86400' "$SETTINGS_FILE" 2>/dev/null)
RETRY_MAX=$(jq -r '.retry_max // 3' "$SETTINGS_FILE" 2>/dev/null)
RETRY_BACKOFF_BASE=$(jq -r '.retry_backoff_base // 2' "$SETTINGS_FILE" 2>/dev/null)
RETRY_BACKOFF_MAX=$(jq -r '.retry_backoff_max // 120' "$SETTINGS_FILE" 2>/dev/null)

# Proxy configuration (required for regions where NotebookLM is blocked)
NLM_PROXY=$(jq -r '.proxy // ""' "$SETTINGS_FILE" 2>/dev/null)
if [[ -n "$NLM_PROXY" ]]; then
  export https_proxy="$NLM_PROXY"
  export http_proxy="$NLM_PROXY"
fi

# --- Helpers ---

json_error() {
  local category="$1" message="$2" detail="${3:-}"
  jq -n -c --arg cat "$category" --arg msg "$message" --arg det "$detail" \
    '{"ok":false,"error":$cat,"message":$msg,"detail":$det}'
}

json_ok() {
  local data="$1"
  jq -n -c --argjson d "$data" '{"ok":true,"data":$d}'
}

# --- Audit Log (NFR-6) ---

audit_log() {
  local agent="$1" notebook="${2:-}" operation="$3" status="$4" latency_ms="${5:-0}" error="${6:-}"
  mkdir -p "$(dirname "$AUDIT_LOG")"
  local ts
  ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  jq -n -c \
    --arg ts "$ts" --arg agent "$agent" --arg nb "$notebook" \
    --arg op "$operation" --arg st "$status" \
    --argjson lat "$latency_ms" --arg err "$error" \
    '{"timestamp":$ts,"agent":$agent,"notebook":$nb,"operation":$op,"status":$st,"latency_ms":$lat,"error":$err}' \
    >> "$AUDIT_LOG"
}

# --- Retry with exponential backoff ---

retry_cli() {
  # Usage: retry_cli <description> <command...>
  # Delegates to retry_with_backoff from lib/queue.sh
  local desc="$1"
  shift
  retry_with_backoff "$@"
}

cleanup() {
  release_lock >/dev/null 2>&1 || true
}
trap cleanup EXIT

# --- Command: query ---

cmd_query() {
  local agent_id="$1" notebook="$2" query="$3" no_cache="${4:-false}"
  local _start_ts=$SECONDS

  if [[ -z "$notebook" || -z "$query" ]]; then
    json_error "invalid_args" "notebook and query required"
    return 1
  fi

  # ACL check
  local acl_result
  acl_result=$(check_acl "$agent_id" "$notebook" "query")
  if [[ $(echo "$acl_result" | jq -r '.allowed') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "query" "denied" "$(( SECONDS - _start_ts ))" "acl_denied"
    echo "$acl_result"
    return 1
  fi

  # Rate check
  local rate_result
  rate_result=$(rate_check "$agent_id")
  if [[ $(echo "$rate_result" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "query" "rate_limited" "$(( SECONDS - _start_ts ))" "rate_limited"
    echo "$rate_result"
    return 1
  fi

  # Resolve notebook ID from registry
  local nb_entry nb_id
  nb_entry=$(registry_get "$notebook")
  if [[ $(echo "$nb_entry" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "query" "error" "$(( SECONDS - _start_ts ))" "notebook_not_found"
    echo "$nb_entry"
    return 1
  fi
  nb_id=$(echo "$nb_entry" | jq -r '.notebook.id')

  # Cache check — no lock needed for cache hit (Fix #8)
  local cache_key="${notebook}:${query}"
  if [[ "$no_cache" != "true" ]]; then
    local cache_result
    cache_result=$(cache_get "query" "$cache_key" "$CACHE_TTL_QUERY")
    if [[ $(echo "$cache_result" | jq -r '.hit') == "true" ]]; then
      local cached_data
      cached_data=$(echo "$cache_result" | jq -c '.data')
      audit_log "$agent_id" "$notebook" "query" "cache_hit" "$(( SECONDS - _start_ts ))"
      printf '%s\n' "$cached_data" | jq -c '{ok:true,cached:true,data:.}'
      return 0
    fi
  fi

  # Acquire lock only when calling CLI (Fix #8)
  local lock_result
  lock_result=$(acquire_lock "$LOCK_TIMEOUT")
  if [[ $(echo "$lock_result" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "query" "error" "$(( SECONDS - _start_ts ))" "lock_timeout"
    echo "$lock_result"
    return 1
  fi

  # Execute CLI with retry (Fix #3)
  local output exit_code
  output=$(retry_cli "query" notebooklm ask -n "$nb_id" --json "$query")
  exit_code=$?

  release_lock >/dev/null 2>&1

  if [[ $exit_code -ne 0 ]]; then
    local safe_output
    safe_output=$(echo "$output" | head -5 | tr '\n' ' ')
    audit_log "$agent_id" "$notebook" "query" "error" "$(( SECONDS - _start_ts ))" "$safe_output"
    json_error "cli_error" "notebooklm query failed" "$safe_output"
    return 1
  fi

  # Cache result
  cache_set "query" "$cache_key" "$output" >/dev/null 2>&1

  audit_log "$agent_id" "$notebook" "query" "ok" "$(( SECONDS - _start_ts ))"
  printf '%s\n' "$output" | jq -c '{ok:true,cached:false,data:.}'
  return 0
}

# --- Command: source ---

cmd_source() {
  local agent_id="$1" subcmd="$2" notebook="$3"
  shift 3

  case "$subcmd" in
    add)
      cmd_source_add "$agent_id" "$notebook" "$@"
      ;;
    list)
      cmd_source_list "$agent_id" "$notebook" "$@"
      ;;
    remove)
      cmd_source_remove "$agent_id" "$notebook" "$@"
      ;;
    *)
      json_error "invalid_args" "Unknown source subcommand: $subcmd" "Valid: add, list, remove"
      return 1
      ;;
  esac
}

cmd_source_add() {
  local agent_id="$1" notebook="$2" source_path="$3"
  local _start_ts=$SECONDS

  if [[ -z "$notebook" || -z "$source_path" ]]; then
    json_error "invalid_args" "notebook and source_path required"
    return 1
  fi

  # ACL check
  local acl_result
  acl_result=$(check_acl "$agent_id" "$notebook" "source-add")
  if [[ $(echo "$acl_result" | jq -r '.allowed') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "source-add" "denied" "$(( SECONDS - _start_ts ))" "acl_denied"
    echo "$acl_result"
    return 1
  fi

  # Content filter
  # Canonicalize path to prevent ../ and symlink bypass (Fix #1)
  if command -v python3 &>/dev/null; then
    source_path="$(python3 -c "import os,sys; print(os.path.realpath(os.path.expanduser(sys.argv[1])))" "$source_path")"
  fi
  local filter_result
  filter_result=$(content_filter "$source_path")
  if [[ $(echo "$filter_result" | jq -r '.allowed') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "source-add" "denied" "$(( SECONDS - _start_ts ))" "content_filter"
    echo "$filter_result"
    return 1
  fi

  # Rate check
  local rate_result
  rate_result=$(rate_check "$agent_id")
  if [[ $(echo "$rate_result" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "source-add" "rate_limited" "$(( SECONDS - _start_ts ))" "rate_limited"
    echo "$rate_result"
    return 1
  fi

  # Resolve notebook ID
  local nb_entry nb_id
  nb_entry=$(registry_get "$notebook")
  if [[ $(echo "$nb_entry" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "source-add" "error" "$(( SECONDS - _start_ts ))" "notebook_not_found"
    echo "$nb_entry"
    return 1
  fi
  nb_id=$(echo "$nb_entry" | jq -r '.notebook.id')

  # Acquire lock for CLI call
  local lock_result
  lock_result=$(acquire_lock "$LOCK_TIMEOUT")
  if [[ $(echo "$lock_result" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "source-add" "error" "$(( SECONDS - _start_ts ))" "lock_timeout"
    echo "$lock_result"
    return 1
  fi

  # Execute CLI with retry
  local output exit_code
  output=$(retry_cli "source-add" notebooklm source add -n "$nb_id" --json "$source_path")
  exit_code=$?

  release_lock >/dev/null 2>&1

  if [[ $exit_code -ne 0 ]]; then
    local safe_output
    safe_output=$(echo "$output" | head -5 | tr '\n' ' ')
    audit_log "$agent_id" "$notebook" "source-add" "error" "$(( SECONDS - _start_ts ))" "$safe_output"
    json_error "cli_error" "source add failed" "$safe_output"
    return 1
  fi

  # Invalidate source list cache
  cache_invalidate "source_list" "$notebook" >/dev/null 2>&1

  audit_log "$agent_id" "$notebook" "source-add" "ok" "$(( SECONDS - _start_ts ))"
  printf '%s\n' "$output" | jq -c --arg nb "$notebook" --arg sp "$source_path" \
    '{"ok":true,"action":"source_added","notebook":$nb,"source":$sp,"data":.}'
  return 0
}

cmd_source_list() {
  local agent_id="$1" notebook="$2" no_cache="${3:-false}"
  local _start_ts=$SECONDS

  if [[ -z "$notebook" ]]; then
    json_error "invalid_args" "notebook required"
    return 1
  fi

  # ACL check
  local acl_result
  acl_result=$(check_acl "$agent_id" "$notebook" "source-list")
  if [[ $(echo "$acl_result" | jq -r '.allowed') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "source-list" "denied" "$(( SECONDS - _start_ts ))" "acl_denied"
    echo "$acl_result"
    return 1
  fi

  # Rate check
  local rate_result
  rate_result=$(rate_check "$agent_id")
  if [[ $(echo "$rate_result" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "source-list" "rate_limited" "$(( SECONDS - _start_ts ))" "rate_limited"
    echo "$rate_result"
    return 1
  fi

  # Resolve notebook ID
  local nb_entry nb_id
  nb_entry=$(registry_get "$notebook")
  if [[ $(echo "$nb_entry" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "source-list" "error" "$(( SECONDS - _start_ts ))" "notebook_not_found"
    echo "$nb_entry"
    return 1
  fi
  nb_id=$(echo "$nb_entry" | jq -r '.notebook.id')

  # Cache check — no lock needed for cache hit (Fix #8)
  if [[ "$no_cache" != "true" ]]; then
    local cache_result
    cache_result=$(cache_get "source_list" "$notebook" "$CACHE_TTL_SOURCE_LIST")
    if [[ $(echo "$cache_result" | jq -r '.hit') == "true" ]]; then
      local cached_data
      cached_data=$(echo "$cache_result" | jq -c '.data')
      audit_log "$agent_id" "$notebook" "source-list" "cache_hit" "$(( SECONDS - _start_ts ))"
      printf '%s\n' "$cached_data" | jq -c '{"ok":true,"cached":true,"data":.}'
      return 0
    fi
  fi

  # Acquire lock only when calling CLI (Fix #8)
  local lock_result
  lock_result=$(acquire_lock "$LOCK_TIMEOUT")
  if [[ $(echo "$lock_result" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "source-list" "error" "$(( SECONDS - _start_ts ))" "lock_timeout"
    echo "$lock_result"
    return 1
  fi

  # Execute CLI with retry
  local output exit_code
  output=$(retry_cli "source-list" notebooklm source list -n "$nb_id" --json)
  exit_code=$?

  release_lock >/dev/null 2>&1

  if [[ $exit_code -ne 0 ]]; then
    local safe_output
    safe_output=$(echo "$output" | head -5 | tr '\n' ' ')
    audit_log "$agent_id" "$notebook" "source-list" "error" "$(( SECONDS - _start_ts ))" "$safe_output"
    json_error "cli_error" "source list failed" "$safe_output"
    return 1
  fi

  cache_set "source_list" "$notebook" "$output" >/dev/null 2>&1

  audit_log "$agent_id" "$notebook" "source-list" "ok" "$(( SECONDS - _start_ts ))"
  printf '%s\n' "$output" | jq -c '{"ok":true,"cached":false,"data":.}'
  return 0
}

cmd_source_remove() {
  local agent_id="$1" notebook="$2" source_id="$3"
  local _start_ts=$SECONDS

  if [[ -z "$notebook" || -z "$source_id" ]]; then
    json_error "invalid_args" "notebook and source_id required"
    return 1
  fi

  # ACL check — admin/contributor only
  local acl_result
  acl_result=$(check_acl "$agent_id" "$notebook" "source-remove")
  if [[ $(echo "$acl_result" | jq -r '.allowed') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "source-remove" "denied" "$(( SECONDS - _start_ts ))" "acl_denied"
    echo "$acl_result"
    return 1
  fi

  # Resolve notebook ID
  local nb_entry nb_id
  nb_entry=$(registry_get "$notebook")
  if [[ $(echo "$nb_entry" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "source-remove" "error" "$(( SECONDS - _start_ts ))" "notebook_not_found"
    echo "$nb_entry"
    return 1
  fi
  nb_id=$(echo "$nb_entry" | jq -r '.notebook.id')

  # Acquire lock for CLI call
  local lock_result
  lock_result=$(acquire_lock "$LOCK_TIMEOUT")
  if [[ $(echo "$lock_result" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "source-remove" "error" "$(( SECONDS - _start_ts ))" "lock_timeout"
    echo "$lock_result"
    return 1
  fi

  # Execute CLI with retry
  local output exit_code
  output=$(retry_cli "source-remove" notebooklm source delete -n "$nb_id" "$source_id" --json)
  exit_code=$?

  release_lock >/dev/null 2>&1

  if [[ $exit_code -ne 0 ]]; then
    local safe_output
    safe_output=$(echo "$output" | head -5 | tr '\n' ' ')
    audit_log "$agent_id" "$notebook" "source-remove" "error" "$(( SECONDS - _start_ts ))" "$safe_output"
    json_error "cli_error" "source remove failed" "$safe_output"
    return 1
  fi

  cache_invalidate "source_list" "$notebook" >/dev/null 2>&1

  audit_log "$agent_id" "$notebook" "source-remove" "ok" "$(( SECONDS - _start_ts ))"
  jq -n -c --arg nb "$notebook" --arg sid "$source_id" \
    '{"ok":true,"action":"source_removed","notebook":$nb,"source_id":$sid}'
  return 0
}

# --- Command: artifact ---

cmd_artifact() {
  local agent_id="$1" subcmd="$2" notebook="$3"
  shift 3
  local _start_ts=$SECONDS

  local operation="artifact-${subcmd}"

  # ACL check
  local acl_result
  acl_result=$(check_acl "$agent_id" "$notebook" "$operation")
  if [[ $(echo "$acl_result" | jq -r '.allowed') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "$operation" "denied" "$(( SECONDS - _start_ts ))" "acl_denied"
    echo "$acl_result"
    return 1
  fi

  # Rate check
  local rate_result
  rate_result=$(rate_check "$agent_id")
  if [[ $(echo "$rate_result" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "$operation" "rate_limited" "$(( SECONDS - _start_ts ))" "rate_limited"
    echo "$rate_result"
    return 1
  fi

  # Resolve notebook ID
  local nb_entry nb_id
  nb_entry=$(registry_get "$notebook")
  if [[ $(echo "$nb_entry" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "$operation" "error" "$(( SECONDS - _start_ts ))" "notebook_not_found"
    echo "$nb_entry"
    return 1
  fi
  nb_id=$(echo "$nb_entry" | jq -r '.notebook.id')

  # Acquire lock for CLI call
  local lock_result
  lock_result=$(acquire_lock "$LOCK_TIMEOUT")
  if [[ $(echo "$lock_result" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "$operation" "error" "$(( SECONDS - _start_ts ))" "lock_timeout"
    echo "$lock_result"
    return 1
  fi

  case "$subcmd" in
    generate)
      local output exit_code
      output=$(retry_cli "artifact-generate" notebooklm generate -n "$nb_id" --json "$@")
      exit_code=$?

      release_lock >/dev/null 2>&1

      if [[ $exit_code -ne 0 ]]; then
        local safe_output
        safe_output=$(echo "$output" | head -5 | tr '\n' ' ')
        audit_log "$agent_id" "$notebook" "$operation" "error" "$(( SECONDS - _start_ts ))" "$safe_output"
        json_error "cli_error" "artifact generate failed" "$safe_output"
        return 1
      fi
      audit_log "$agent_id" "$notebook" "$operation" "ok" "$(( SECONDS - _start_ts ))"
      printf '%s\n' "$output" | jq -c --arg nb "$notebook" \
        '{"ok":true,"action":"artifact_generated","notebook":$nb,"data":.}'
      ;;
    download)
      local artifact_id="${1:-}"
      if [[ -z "$artifact_id" ]]; then
        release_lock >/dev/null 2>&1
        json_error "invalid_args" "artifact_id required for download"
        return 1
      fi
      local staging_dir="$DATA_DIR/artifacts"
      mkdir -p "$staging_dir"
      local output exit_code
      output=$(retry_cli "artifact-download" notebooklm download "$artifact_id" -n "$nb_id" --output "$staging_dir" --json)
      exit_code=$?

      release_lock >/dev/null 2>&1

      if [[ $exit_code -ne 0 ]]; then
        local safe_output
        safe_output=$(echo "$output" | head -5 | tr '\n' ' ')
        audit_log "$agent_id" "$notebook" "$operation" "error" "$(( SECONDS - _start_ts ))" "$safe_output"
        json_error "cli_error" "artifact download failed" "$safe_output"
        return 1
      fi
      audit_log "$agent_id" "$notebook" "$operation" "ok" "$(( SECONDS - _start_ts ))"
      printf '%s\n' "$output" | jq -c --arg nb "$notebook" --arg sd "$staging_dir" \
        '{"ok":true,"action":"artifact_downloaded","notebook":$nb,"staging_dir":$sd,"data":.}'
      ;;
    *)
      release_lock >/dev/null 2>&1
      json_error "invalid_args" "Unknown artifact subcommand: $subcmd" "Valid: generate, download"
      return 1
      ;;
  esac
}

# --- Command: research ---

cmd_research() {
