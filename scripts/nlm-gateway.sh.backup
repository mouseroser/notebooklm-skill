    echo "$nb_entry"
    return 1
  fi
  nb_id=$(echo "$nb_entry" | jq -r '.notebook.id')

  # Acquire lock for CLI call
  local lock_result
  lock_result=$(acquire_lock "$LOCK_TIMEOUT")
  if [[ $(echo "$lock_result" | jq -r '.ok') != "true" ]]; then
    audit_log "$agent_id" "$notebook" "research" "error" "$(( SECONDS - _start_ts ))" "lock_timeout"
    echo "$lock_result"
    return 1
